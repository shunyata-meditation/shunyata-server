# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings (PostgreSQL)
DB_NAME=shunyata
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=5432
# Use "require" for hosted databases like Neon that require SSL (set to "prefer" for local dev)
DB_SSLMODE=prefer

# Email Settings (SMTP)
# For development, use: django.core.mail.backends.console.EmailBackend (prints to terminal)
# For production, use: django.core.mail.backends.smtp.EmailBackend (sends real emails)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Email Verification Settings
VERIFICATION_EMAIL_EXPIRY_HOURS=24
FRONTEND_URL=http://localhost:3000

# Security: Allowed Redirect Domains
# Comma-separated list of external domains allowed for post-login redirects
# Example: ALLOWED_REDIRECT_DOMAINS=app.shunyata.com,mobile.shunyata.com
ALLOWED_REDIRECT_DOMAINS=
